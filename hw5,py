# ─── Security Controls ───

class SecurityGuard:
    # 惡意指令與敏感詞黑名單
    BLOCKED_KEYWORDS = [
        "rm -rf", "mkfs", "dd if=", ":(){ :|:& };:", "chmod 777", 
        "chown", "passwd", "shadow", "wget", "curl", "ssh"
    ]
    
    # 潛在的 Prompt 注入攻擊詞
    INJECTION_KEYWORDS = [
        "ignore previous instructions", "忽略上述指令", "system prompt", "你現在是"
    ]

    @classmethod
    def verify_input(cls, user_input: str) -> bool:
        """檢查使用者輸入是否包含惡意 Prompt 注入"""
        lowered_input = user_input.lower()
        for kw in cls.INJECTION_KEYWORDS:
            if kw in lowered_input:
                print(f"\n[安全警報] 偵測到潛在的 Prompt 注入攻擊關鍵字: '{kw}'")
                return False
        return True

    @classmethod
    def verify_command(cls, command: str) -> bool:
        """檢查即將執行的指令是否包含高風險操作"""
        lowered_cmd = command.lower()
        
        # 1. 檢查黑名單
        for kw in cls.BLOCKED_KEYWORDS:
            if kw in lowered_cmd:
                print(f"\n[安全攔截] 該指令包含高風險危險詞 '{kw}'，系統直接拒絕執行！")
                return False
                
        # 2. 檢查是否有意圖跳出工作目錄的行為 (路徑穿越檢測)
        if "../" in command or " /" in command:
            # 排除合法的 workspace 路徑，防止試圖存取系統根目錄
            if not any(safe_path in command for safe_path in ["~/.agent0", ".agent0"]):
                print(f"\n[安全攔截] 偵測到潛在的路徑穿越 (Path Traversal) 攻擊，禁止存取工作區外的目錄！")
                return False
                
        return True


class os:
    @staticmethod
    def makedirs(path, exist_ok=False):
        print(f"\n[權限請求] 程式想要建立目錄: {path}")
        use = input("是否允許此操作？ (yes/no): ").strip().lower()
        if use == "yes":
            return oss.makedirs(path, exist_ok=exist_ok)
        else:
            raise PermissionError("Directory creation denied")
    
    @staticmethod
    def getcwd():
        # 讀取當前目錄通常較安全，改為自動允許，但加上日誌記錄
        return oss.getcwd()
        
    @staticmethod
    def expanduser(path):
        return oss.path.expanduser(path)


class subprocess:
    @staticmethod
    def run(command, shell=False, capture_output=False, text=False, timeout=None, cwd=None):
        # 1. 自動防禦：先過濾危險指令
        if not SecurityGuard.verify_command(command):
            raise PermissionError("Command blocked by security policy")

        # 2. 人工確認 (Human-in-the-loop)
        print(f"\n⚠️  [安全審查] AI 請求執行以下系統指令:")
        print(f"----------------------------------------")
        print(f" 💻 $ {command}")
        print(f"----------------------------------------")
        
        use = input("確定要執行此指令嗎？ (yes/no): ").strip().lower()
        if use == "yes":
            # 使用 shlex.split 可以有效降低 shell=True 的注入風險，但此處配合 shell=True 仍需小心
            return subprocesss.run(command, shell=shell, capture_output=capture_output, text=text, timeout=timeout, cwd=cwd)
        else:
            raise PermissionError("Command execution denied by user")


# ─── Configuration ───

WORKSPACE = os.expanduser("~/.agent0")
MODEL = "minimax-m2.5:cloud"
MAX_TURNS = 5

# ─── Memory ───

conversation_history = []
key_info = []

# ─── Tools ───

TOOLS = [
    {
        "name": "run_command",
        "description": "Run a shell command (Only operations inside the workspace are allowed. e.g., 'cat file')",
        "input_schema": {
            "type": "object",
            "properties": {
                "command": {"type": "string", "description": "The command to run"}
            },
            "required": ["command"]
        }
    },
]

# ─── Ollama API ───

async def call_ollama(prompt: str, system: str = "") -> str:
    """Call Ollama API"""
    full_prompt = f"{system}\n\n{prompt}" if system else prompt
    
    payload = {
        "model": MODEL,
        "prompt": full_prompt,
        "stream": False
    }
    
    try:
        async with aiohttp.ClientSession() as session:
            async with session.post(
                "http://localhost:11434/api/generate",
                json=payload,
                timeout=aiohttp.ClientTimeout(total=120)
            ) as resp:
                result = await resp.json()
                return result.get("response", "").strip()
    except Exception as e:
        return f"Error connecting to Ollama: {e}"

# ─── Tool Execution ───

def execute_tool(name, tool_input):
    print(f"\n=== TOOL EXECUTE ===")
    print(f"Tool: {name}")
    print(f"Input: {tool_input}")
    
    if name == "run_command":
        try:
            # 確保指令在 WORKSPACE 中執行，落實沙盒隔離 (Sandbox Target)
            result = subprocess.run(
                tool_input["command"], shell=True, 
                capture_output=True, text=True, timeout=30,
                cwd=WORKSPACE  # 強制將工作路徑鎖定在 WORKSPACE
            )
            output = result.stdout + result.stderr
            print(f"Result: {output}")
            print(f"=== END ===\n")
            return output if output else "(no output)"
        except Exception as e:
            print(f"Error: {e}")
            print(f"=== END ===\n")
            return f"Error: {e}"
    
    print(f"=== END ===\n")
    return f"Unknown tool: {name}"

# ─── Memory Management ───

def build_context():
    context_parts = []
    if key_info:
        context_parts.append("Key information:\n" + "\n".join(f"- {k}" for k in key_info))
    if conversation_history:
        context_parts.append("Recent conversation:\n" + "\n".join(conversation_history[-MAX_TURNS*2:]))
    return "\n\n".join(context_parts)

def update_memory(user_input, assistant_response, tool_result=None):
    conversation_history.append(f"User: {user_input}")
    conversation_history.append(f"Assistant: {assistant_response}")
    if tool_result:
        conversation_history.append(f"Tool result: {tool_result[:500]}")
    
    while len(conversation_history) > MAX_TURNS * 4:
        conversation_history.pop(0)

async def extract_key_info(user_input, assistant_response):
    extract_prompt = f"""Based on this conversation, should any key information be remembered long-term?
If yes, output a JSON list of key points (max 2). If no, output an empty list [].

Conversation:
User: {user_input}
Assistant: {assistant_response}

Key information to remember:"""
    
    try:
        result = await call_ollama(extract_prompt, "")
        match = re.search(r'\[.*\]', result, re.DOTALL)
        if match:
            items = json.loads(match.group(0))
            for item in items:
                if item not in key_info:
                    key_info.append(item)
    except:
        pass

# ─── Agent ───

# 在 System Prompt 中強調安全限制，防止 AI 本身越權
SYSTEM_PROMPT = f"""You are Jarvis, a helpful AI assistant.
You have tools - use them to help the user.

CRITICAL SECURITY RULE: You are strictly isolated in the workspace directory: {WORKSPACE}.
Never attempt to access, read, or delete files outside of this directory. Do not run any destructive commands.

Available tools:
- run_command: Run a shell command. Use 'cat file' to read files, 'echo content > file' or 'printf' to write files.

When you need to use a tool, output in this format:
<tool>
{{"name": "tool_name", "input": {{"key": "value"}}}}
</tool>

Otherwise, just respond directly."""

def main():
    # 確保初始工作區存在
    if not oss.path.exists(WORKSPACE):
        oss.makedirs(WORKSPACE, exist_ok=True)
    
    print(f"Agent0 - {MODEL} (with Enhanced Safety Control)")
    print(f"Workspace: {WORKSPACE}")
    print("Commands: /quit, /memory (show key info)\n")
    
    while True:
        try:
            user_input = input("You: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nGoodbye!")
            break
        
        if not user_input:
            continue
        if user_input.lower() in ["/quit", "/exit", "/q"]:
            print("Goodbye!")
            break
        if user_input.lower() == "/memory":
            print(f"Key info: {key_info}")
            continue
            
        # 【安全防護第一關】檢查使用者輸入是否安全
        if not SecurityGuard.verify_input(user_input):
            print("🤖 系統偵測到潛在不安全的要求，已拒絕此請求。\n")
            continue
        
        context = build_context()
        full_prompt = f"{context}\n\nUser: {user_input}" if context else f"User: {user_input}"
        
        response = asyncio.run(call_ollama(full_prompt, SYSTEM_PROMPT))
        
        tool_result = None
        current_response = response
        
        while True:
            tool_matches = re.findall(r'<tool>(.+?)</tool>', current_response, re.DOTALL)
            if not tool_matches:
                break
            
            all_tool_outputs = []
            for tool_match in tool_matches:
                try:
                    tool_json = tool_match.strip()
                    tool_data = json.loads(tool_json)
                    tool_name = tool_data.get("name")
                    tool_input = tool_data.get("input", {})
                    
                    tool_output = execute_tool(tool_name, tool_input)
                    all_tool_outputs.append(f"[{tool_name}]: {tool_output}")
                except json.JSONDecodeError as e:
                    print(f"JSON parse error: {e}")
                    print(f"Raw tool data: {tool_match}")
                    all_tool_outputs.append(f"Error: Tool invocation format error.")
                except Exception as e:
                    print(f"Tool error: {e}")
                    all_tool_outputs.append(f"Error: {e}")
            
            tool_result = (tool_result or "") + "\n" + "\n".join(all_tool_outputs)
            
            follow_up_prompt = f"""Previous context: {context}

User: {user_input}
Previous assistant responses: {current_response}
Tool outputs:
{chr(10).join(all_tool_outputs)}

If you need more tools, output them. Otherwise, provide your final response to the user:"""
            current_response = asyncio.run(call_ollama(follow_up_prompt, SYSTEM_PROMPT))
        
        response = current_response
        
        print(f"\n🤖 {response}\n")
        
        update_memory(user_input, response, tool_result)
        if tool_result:
            asyncio.run(extract_key_info(user_input, response))

if __name__ == "__main__":
    main()
